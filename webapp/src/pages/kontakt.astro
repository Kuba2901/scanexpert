---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Kontakt - Scan Expert">
  <section id="kontakt" style="padding-top: 140px; border-top: none; background: transparent;">
    <div class="container">
      <div class="section-label">Kontakt</div>
      <h2>Skontaktuj się z nami<br><strong>zacznijmy tworzyć razem</strong></h2>
      <p class="section-intro">Jesteśmy tutaj, aby pomóc przekształcić Twoje pomysły w rzeczywistość. Nasi eksperci są gotowi udzielić profesjonalnej odpowiedzi na każdym kroku projektu.</p>

      <div class="contact-grid">
        
        <form class="contact-form" onsubmit="return false;">
          <div class="form-row">
            <input type="text" placeholder="Imię" required>
            <input type="email" placeholder="Adres Email" required>
          </div>
          <input type="tel" placeholder="Numer telefonu">
          <textarea placeholder="Wiadomość..." required></textarea>
          <button type="submit" class="btn-primary" style="align-self:flex-start;">Wyślij</button>
        </form>

        <div class="contact-info">
          <div class="contact-block">
            <div class="contact-label">E-mail</div>
            <a href="mailto:biuro@scanexpert.pl" class="contact-val">biuro@scanexpert.pl</a>
            <a href="mailto:biuro@scan-expert.pl" class="contact-val">biuro@scan-expert.pl</a>
          </div>
          <div class="contact-block">
            <div class="contact-label">Telefon</div>
            <a href="tel:+48536297099" class="contact-val">+48 536 297 099</a>
            <a href="tel:+48609343533" class="contact-val">+48 609 343 533</a>
            <a href="tel:+48609153433" class="contact-val">+48 609 153 433</a>
          </div>
          <div class="contact-block">
            <div class="contact-label">Social media</div>
            <a href="https://www.linkedin.com/company/scanexpert-architecture-civil-technology" class="contact-val" target="_blank">LinkedIn</a>
            <a href="https://www.facebook.com/profile.php?id=61567747955996" class="contact-val" target="_blank">Facebook</a>
          </div>
          <div class="company-info">
            PPHU „JAPIL" JAKUB PILARSKI<br>
            NIP: 7272531264
          </div>
        </div>

      </div>
    </div>
  </section>
</MainLayout>