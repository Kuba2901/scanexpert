---
// src/pages/uslugi/skan-3d-budynkow.astro
import MainLayout from '../../layouts/MainLayout.astro';
---
<MainLayout title="Skan 3D obiektów budowlanych - Scan Expert">
  <section style="padding-top: 140px;">
    <div class="container">
      <div class="section-label">Usługi</div>
      <h1>Inwentaryzacja <strong>architektoniczno-budowlana</strong></h1>
      
      <p class="section-intro">Wykorzystujemy najnowocześniejsze skanery laserowe, aby uzyskać wysokiej rozdzielczości chmurę punktów z milimetrową dokładnością[cite: 8, 9].</p>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; margin-top: 40px;">
        <img src="https://scanexpert.pl/wp-content/uploads/2026/04/Zrzut-ekranu-2025-11-11-094301.png" alt="Inwentaryzacja 3D" style="width: 100%; border-radius: var(--radius-lg);"/>
        
        <div>
          <h3>Zakres prac:</h3>
          <ul style="color: var(--text2); line-height: 2;">
            <li>Dokumentacje powykonawcze i rzuty .dwg [cite: 41, 52]</li>
            <li>Archiwizacja detali sztukatorskich w zabytkach [cite: 41, 71]</li>
            <li>Kontrole odkształceń elementów stalowych [cite: 41]</li>
            <li>Modele BIM w standardzie Revit [cite: 51, 52]</li>
          </ul>
          <div style="margin-top: 30px; border-left: 2px solid var(--accent); padding-left: 20px;">
            <p style="font-family: var(--mono); font-size: 13px;">"Jako inżynierowie budownictwa rozumiemy potrzeby branży i dostarczamy dane gotowe do projektowania"[cite: 41, 63].</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>