---
// src/pages/uslugi/druk-3d.astro
import MainLayout from '../../layouts/MainLayout.astro';
---
<MainLayout title="Druk 3D - Scan Expert">
  <section style="padding-top: 140px; min-height: 80vh;">
    <div class="container">
      <div class="section-label">Usługi</div>
      <h1>Druk <strong>3D</strong></h1>
      
      <div class="specs-layout" style="margin-top: 60px;">
        <div>
          <h2>Jak to działa?</h2>
          <p class="section-intro">Przekształcamy modele 3D w fizyczne makiety budynków, prototypy inżynierskie lub odtwarzamy detale sztukatorskie w sposób bezinwazyjny[cite: 17, 22].</p>
          
          <h3 style="margin-top: 30px; color: var(--accent);">Parametry techniczne</h3>
          <div class="spec-row">
            <span class="spec-name">Technologia</span>
            <span class="spec-val">FFF (Fused Filament Fabrication) [cite: 32]</span>
          </div>
          <div class="spec-row">
            <span class="spec-name">Obszar pola roboczego</span>
            <span class="spec-val">420mm x 300mm x 400mm [cite: 32]</span>
          </div>
          <div class="spec-row">
            <span class="spec-name">Rozdzielczość wydruku</span>
            <span class="spec-val">do 0,05 mm [cite: 32]</span>
          </div>
          <div class="spec-row">
            <span class="spec-name">Dostępne materiały</span>
            <span class="spec-val">PLA, ABS, Nylon, PET-G, TPU, PVA, Kompozyty, PP, PA+ [cite: 32]</span>
          </div>
        </div>

        <div>
          <img 
            src="https://scanexpert.pl/wp-content/uploads/2026/04/Gemini_Generated_Image_q3y4zq3y4zq3y4zq-1024x559.png" 
            alt="Druk 3D budynku" 
            style="width: 100%; border-radius: var(--radius-lg); border: 1px solid var(--border2);"
          />
          <div style="margin-top: 20px; background: var(--bg3); padding: 20px; border-radius: var(--radius);">
            <h4 style="font-family: var(--mono); font-size: 14px; margin-bottom: 10px; color: var(--accent);">Zastosowania:</h4>
            <ul style="font-size: 14px; color: var(--text2); line-height: 1.8;">
              <li>Makiety zeskanowanych obiektów (Scan to Print) [cite: 28]</li>
              <li>Produkcja małych serii części zamiennych [cite: 29]</li>
              <li>Modele edukacyjne i demonstracyjne [cite: 30]</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>